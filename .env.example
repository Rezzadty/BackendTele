PORT=3000
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Firebase source (microcontroller writes data here)
FIREBASE_DATABASE_URL=
FIREBASE_AUTH_TOKEN=
FIREBASE_API_KEY=
FIREBASE_AUTH_EMAIL=
FIREBASE_AUTH_PASSWORD=
FIREBASE_SENSOR_PATH=SensorData/latest
ENABLE_FIREBASE_POLLING_WORKER=true
FIREBASE_POLL_INTERVAL_MS=1000

# MQ status detection rule
SENSOR_STATUS_FIELDS=mq135_status,mq7_status
SENSOR_DANGER_STATUS_VALUES=dangerous
SENSOR_CLEAN_STATUS_VALUES=clean

SENSOR_EVENT_TIMESTAMP_FIELD=timestamp
SENSOR_OFFLINE_AFTER_MS=60000
ALERT_ON_MISSING_DATA=true

# Notification behavior for repeated issue events
MAX_ISSUE_NOTIFICATIONS=1
SEND_RESOLVED_NOTIFICATION=true

# Default delivery targets for worker-triggered notifications
DEFAULT_TELEGRAM_CHAT_ID=
