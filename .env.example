PORT=3000
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_BACKUP_MODE=on-failure

# Firebase source (microcontroller writes data here)
FIREBASE_DATABASE_URL=
FIREBASE_AUTH_TOKEN=
FIREBASE_SENSOR_PATH=sensor/latest
ENABLE_FIREBASE_POLLING_WORKER=true
FIREBASE_POLL_INTERVAL_MS=5000

# Issue detection rule from status field
SENSOR_STATUS_FIELD=status
SENSOR_BAD_STATUS_VALUES=warning,danger,error,critical

# Optional numeric rule: if SENSOR_VALUE_FIELD > SENSOR_VALUE_THRESHOLD, trigger alert
SENSOR_VALUE_FIELD=
SENSOR_VALUE_THRESHOLD=
SENSOR_EVENT_TIMESTAMP_FIELD=updatedAt
ALERT_ON_MISSING_DATA=true

# Notification behavior for repeated issue events
NOTIFICATION_COOLDOWN_MS=120000
SEND_RESOLVED_NOTIFICATION=true

# Default delivery targets for worker-triggered notifications
DEFAULT_EXPO_PUSH_TOKEN=
DEFAULT_TELEGRAM_CHAT_ID=
